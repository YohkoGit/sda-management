# Copy to `.env` next to docker-compose.yml on berrysmart, fill all values,
# then `chmod 600 .env`. Never commit the populated file.
#
# Variable naming: ASP.NET Core treats `__` as the configuration-section
# separator (equivalent to `:` in appsettings.json). Names are case-sensitive.

# === Database (internal — never exposed off the compose network) ===
POSTGRES_DB=sdac
POSTGRES_USER=sdac
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=

# Connection string the API uses. `host=postgres` is the compose service DNS name.
# IMPORTANT: keep this password in sync with POSTGRES_PASSWORD above.
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=sdac;Username=sdac;Password=__SAME_AS_POSTGRES_PASSWORD__

# === Auth ===
# JWT signing secret. Generate fresh per env: openssl rand -base64 64
# Rotation: change this value and restart api — all users get signed out.
Jwt__Secret=

# Google OAuth (QA-specific client — see https://console.cloud.google.com)
# Redirect URI registered on the client must be: https://qa.sdac.yohko.ca/signin-google
Google__ClientId=
Google__ClientSecret=

# === App config ===
ASPNETCORE_ENVIRONMENT=Production
FrontendUrl=https://qa.sdac.yohko.ca
Cors__AllowedOrigins__0=https://qa.sdac.yohko.ca

# OWNER auto-seeded on first run with this email. The first sign-in matching
# this address becomes the system OWNER (Elisha).
OwnerEmail=elisha.rahar@gmail.com

# Dev-only data seeds (test users, sample activities). Always false in QA/prod.
SeedDevData=false

# === Blob storage (Cloudflare R2 — S3-compatible) ===
# Provider: `S3` (R2 / AWS S3) or `LocalDisk` (fallback only).
BlobStorage__Provider=S3
# R2 endpoint format: https://<account-id>.r2.cloudflarestorage.com
BlobStorage__S3__Endpoint=
BlobStorage__S3__Bucket=sdac-qa-images
# R2 token credentials. See R2 dashboard → Manage R2 API Tokens.
BlobStorage__S3__AccessKeyId=
BlobStorage__S3__SecretAccessKey=

# Used only when BlobStorage__Provider=LocalDisk. Path is inside the api
# container; the compose stack bind-mounts ./avatars-volume here.
BlobStorage__LocalDisk__BasePath=/app/data/blobs

# === Cloudflare Tunnel ===
# Token from Zero Trust → Networks → Tunnels → berrysmart-qa → Install command.
# Treat as a secret — anyone with this token can run a connector for the tunnel.
TUNNEL_TOKEN=
